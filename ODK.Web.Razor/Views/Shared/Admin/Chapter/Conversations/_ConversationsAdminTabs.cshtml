@using ODK.Core.Chapters
@using ODK.Core.Messages
@using ODK.Services.Chapters.ViewModels
@using ODK.Web.Common.Routes
@using ODK.Web.Razor.Models.Components
@model ChapterConversationsAdminPageViewModel
@inject IOdkRoutes OdkRoutes
@{
    var menuItems = new[]
    {
        new MenuItem 
        { 
            Link = OdkRoutes.GroupAdmin.Conversations(Model.Chapter).Path, 
            Text = "Unread", 
            Active = Model.Status == ChapterConversationStatus.Unread 
        },
        new MenuItem 
        { 
            Link = OdkRoutes.GroupAdmin.Conversations(Model.Chapter, ChapterConversationStatus.Read).Path, 
            Text = "Read", 
            Active = Model.Status == ChapterConversationStatus.Read 
        }
    };
}

@await Html.PartialAsync("Components/_Tabs", new TabsViewModel
{
    MenuItems = menuItems
})