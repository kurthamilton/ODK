@using ODK.Core.Messages
@using ODK.Services.Chapters.ViewModels
@using ODK.Web.Common.Routes
@using ODK.Web.Razor.Models.Components
@model ChapterConversationsAdminPageViewModel
@inject IOdkRoutes OdkRoutes
@{
    var menuItems = new[]
    {
        new MenuItem { Link = OdkRoutes.GroupAdmin.Conversations(Model.Chapter).Path, Text = "Unread", Active = Model.Status == MessageStatus.Unread },
        new MenuItem { Link = OdkRoutes.GroupAdmin.Conversations(Model.Chapter, MessageStatus.Read).Path, Text = "Read", Active = Model.Status == MessageStatus.Read },
        new MenuItem { Link = OdkRoutes.GroupAdmin.Conversations(Model.Chapter, MessageStatus.Closed).Path, Text = "Closed", Active = Model.Status == MessageStatus.Closed }
    };
}

@await Html.PartialAsync("Components/_Tabs", new TabsViewModel
{
    MenuItems = menuItems
})