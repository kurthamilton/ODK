@using ODK.Core.Chapters
@using ODK.Core.Extensions
@using ODK.Core.Messages
@using ODK.Core.Utils
@using ODK.Services
@using ODK.Services.Contact.ViewModels
@using ODK.Web.Common.Extensions
@using ODK.Web.Common.Routes
@using ODK.Web.Razor.Models.Components
@model MessagesAdminPageViewModel
@inject IOdkRoutes OdkRoutes

<section class="section section--admin">
    <h2>Messages</h2>

    @await Html.PartialAsync("SiteAdmin/_MessagesTabs", Model)

    @if (Model.Status == MessageStatus.Spam && Model.Messages.Count > 0)
    {
        <div class="my-3">
            <form action="/siteadmin/messages/spam/delete" method="post">
                <button type="submit" class="btn btn-primary" onclick="return confirm('Are you sure you want to delete all spam messages?');">
                    Delete all
                </button>
            </form>
        </div>
    }

    <div class="table-responsive">
        <table class="table table-striped">
            <thead>
            <tr>
                <th>Time</th>
                <th>From</th>
                <th>Message</th>
                <th>Replied</th>
                <th></th>
                <th></th>
            </tr>
            </thead>
            <tbody>
            @foreach (var message in Model.Messages.OrderByDescending(x => x.CreatedUtc))
            {
                <tr>
                    <td>@message.CreatedUtc.ToFriendlyDateTimeString(Model.CurrentMember.TimeZone)</td>
                    <td>@message.FromAddress</td>
                    <td>@message.Message</td>
                    <td>
                        @if (message.RepliedUtc != null)
                        {
                            @await Html.PartialAsync("Components/_Icon", new IconViewModel(IconType.CheckCircle)
                            {
                                Class = "text-success"
                            })
                        }
                    </td>
                    <td>
                        <a href="@OdkRoutes.SiteAdmin.Message(message.Id)">View</a>
                    </td>
                    <td>
                        <form method="post" action="/siteadmin/messages/@message.Id/delete">
                            @*@Html.AntiForgeryToken()*@
                            <button data-bs-toggle="tooltip" data-bs-title="Delete" class="btn-icon text-danger"
                                    onclick="return confirm('Are you sure you want to delete this message?');">
                                    @await Html.PartialAsync("Components/_Icon", new IconViewModel(IconType.Times))
                            </button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>