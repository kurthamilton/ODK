@using ODK.Core.Platforms
@using ODK.Core.Utils
@using ODK.Services.Chapters.ViewModels
@using ODK.Web.Common.Routes
@using ODK.Web.Razor.Models.Chapters
@using ODK.Web.Razor.Models.Components
@using ODK.Web.Razor.Models.Contact
@model GroupConversationPageViewModel
@inject IOdkRoutes OdkRoutes
@{
    var breadcrumbs = new[]
    {
        Model.Platform == PlatformType.DrunkenKnitwits
            ? new MenuItem 
            { 
                Link = OdkRoutes.Groups.Group(Model.Chapter), 
                Text = Model.Chapter.GetDisplayName(Model.Platform)
            }
            : new MenuItem(),
        new MenuItem { Link = OdkRoutes.Groups.Contact(Model.Chapter), Text = "Contact" },
        new MenuItem { Text = Model.Conversation.Subject }
    }.Where(x => !string.IsNullOrEmpty(x.Text))
    .ToArray();
}
@await Html.PartialAsync("Components/_Breadcrumbs", new BreadcrumbsViewModel
{
    Breadcrumbs = breadcrumbs
})

@if (Model.CurrentMember == null)
{
    return;
}

<div class="row mt-section">
    <div class="col-md-8">          
        <section class="section">
            @await Html.PartialAsync("Components/_Panel", new PanelViewModel
            {
                TitleContentFunc = @<h5>Messages</h5>,
                BodyContentFunc = 
                    @<div>
                        @await Html.PartialAsync("Chapters/_Conversation", new ChapterConversationViewModel
                        {
                            Chapter = Model.Chapter,
                            CurrentMember = Model.CurrentMember,
                            MemberId = Model.Conversation.MemberId,
                            Messages = Model.Messages        
                        })
                    </div>
            })    
        </section>

        @if (Model.Conversation.ClosedUtc == null)
        {
            <section class="section">
                @await Html.PartialAsync("Components/_Panel", new PanelViewModel
                {
                    TitleContentFunc = @<h5>Reply</h5>,
                    BodyContentFunc = 
                        @<div>
                            <form action="/groups/@Model.Chapter.Id/conversations/@Model.Conversation.Id/reply" method="post">
                                @*@Html.AntiForgeryToken()*@
                                @await Html.PartialAsync("Groups/_GroupConversationReplyForm", new ChapterConversationReplyFormViewModel())
                            
                                <div class="d-flex">
                                    <button class="btn btn-primary" type="submit">Send</button>

                                    <button class="btn btn-danger ms-auto" type="button"
                                        onclick="return confirm('Are you sure you want to close this conversation?');"
                                        data-submit="#close-conversation-form">
                                        Close
                                    </button>
                                </div>                            
                            </form>
                            <form id="close-conversation-form" method="post" action="/groups/@Model.Chapter.Id/conversations/@Model.Conversation.Id/close">
                            </form>                            
                        </div>
                })
            </section>
        }
        else
        {
            <div class="alert alert-warning mt-3">
                Closed @Model.Conversation.ClosedUtc.Value.ToFriendlyDateTimeString(Model.CurrentMember.TimeZone ?? Model.Chapter.TimeZone)
            </div>
        }
    </div>

    @if (Model.OtherConversations.Count > 0)
    {
        <div class="col-md-4 mt-section mt-md-0">
            @await Html.PartialAsync("Components/_Panel", new PanelViewModel
            {
                TitleContentFunc = @<h5>Other conversations</h5>,
                BodyContentFunc = 
                    @<div class="list-group">
                        @foreach (var dto in Model.OtherConversations.OrderByDescending(x => x.LastMessage.Message.CreatedUtc))
                        {
                            <div class="list-group-item">
                                <div>
                                    <a href="@OdkRoutes.Groups.Conversation(Model.Chapter, dto.Conversation.Id)">
                                        @dto.Conversation.Subject
                                    </a>
                                </div>
                                <div>
                                    @dto.LastMessage.Message.CreatedUtc.ToFriendlyDateTimeString(Model.CurrentMember.TimeZone ?? Model.Chapter.TimeZone)
                                </div>
                            </div>
                        }
                    </div>
            })
        </div>
    }    
</div>