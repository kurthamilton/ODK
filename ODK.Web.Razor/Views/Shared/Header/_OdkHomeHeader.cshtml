@using ODK.Core.Chapters
@using ODK.Core.Members
@using ODK.Core.Platforms
@using ODK.Core.Utils
@using ODK.Services.Chapters
@using ODK.Services.Chapters.ViewModels
@using ODK.Web.Common.Routes
@using ODK.Web.Common.Services
@using ODK.Web.Razor.Models
@using ODK.Web.Razor.Models.Components
@using ODK.Web.Razor.Models.Header
@using ODK.Web.Razor.Services
@inject IOdkRoutes OdkRoutes
@inject IRequestStore RequestStore
@model OdkHomeHeaderViewModel
@{
    var platform = RequestStore.Platform;
    if (platform != PlatformType.DrunkenKnitwits)
    {
        return;
    }

    var member = RequestStore.CurrentMemberOrDefault;

    var continents = Model
        .Countries
        .Select(x => x.Continent)
        .Distinct()
        .OrderBy(x => x)
        .ToArray();

    var countryContinentDictionary = Model
        .Countries
        .ToDictionary(x => x.Id, x => x.Continent);

    var chaptersByContinent = Model
        .Chapters
        .GroupBy(x => countryContinentDictionary[x.CountryId])
        .ToDictionary(x => x.Key, x => x.OrderBy(y => y.Name).ToArray());

    var chapters = Model.Chapters;
    var menuItems = chapters
        .OrderBy(x => x.Name)
        .Select(c => new MenuItem
        {
            ExternalLink = !string.IsNullOrEmpty(c.RedirectUrl) ? c.RedirectUrl : null,
            Link = string.IsNullOrEmpty(c.RedirectUrl) ? OdkRoutes.Groups.Group(c) : null,
            Text = c.GetDisplayName(platform)
        })
        .ToArray();
}

@await Html.PartialAsync("Header/_Header", new HeaderViewModel()
{   
    ImageLink = "/",
    ImageUrl = "/assets/img/home-banner.png",
    Navbar = new NavbarViewModel
    {
        // Always collapsed
        Breakpoint = null,
        Chapter = null,
        Color = "dark",
        CssClass = "navbar--home",
        Member = member,
        MenuItems = continents
            .Select(continent => new MenuItemGroup
            {
                MenuItems = chaptersByContinent[continent]
                    .Select(chapter => new MenuItem
                    {
                        Text = chapter.GetDisplayName(platform),
                        Link = string.IsNullOrEmpty(chapter.RedirectUrl)
                            ? OdkRoutes.Groups.Group(chapter)
                            : null,
                        ExternalLink = chapter.RedirectUrl
                    })
                    .ToArray(),
                Title = continent
            })
            .ToArray()
    }
})