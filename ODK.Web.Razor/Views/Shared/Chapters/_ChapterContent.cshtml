@using ODK.Core.Chapters
@using ODK.Core.Members
@using ODK.Core.SocialMedia
@using ODK.Services.Chapters
@using ODK.Services.Members
@using ODK.Services.SocialMedia
@using ODK.Web.Common.Chapters
@using ODK.Web.Razor.Models.Members
@using ODK.Web.Razor.Models.SocialMedia
@model ChapterPageViewModel

@if (Model.Member == null || Model.Member.ChapterId != Model.Chapter.Id)
{    
    <h3>Welcome!</h3>
    @if (!string.IsNullOrEmpty(Model.Texts?.WelcomeText))
    {
        @Html.Raw(Model.Texts.WelcomeText)
    }
}
else
{
    var latestMembers = Model.LatestMembers;

    var memberListViewModel = new MemberListViewModel(Model.Chapter, latestMembers.Select(x => new ListMemberViewModel(Model.Chapter, x)))
    {
        Cols = 2
    };

    <h3>Latest members</h3>
    
    @await Html.PartialAsync("Members/_MemberList", memberListViewModel)
}
                
@if (Model.InstagramPosts.Count > 0)
{
    <div class="mt-3">
        <h3>Latest from Instagram</h3>
        <div class="row row-cols-2 row-cols-lg-4 g-0">
            @foreach (var post in Model.InstagramPosts)
            {
                <div class="col">
                    @await Html.PartialAsync("Components/_InstagramPost", 
                        new InstagramPostViewModel(Model.Chapter, post.Id, post.Caption, post.ExternalId))
                </div>
            }
        </div>

        <div class="d-flex justify-content-end align-content-center">
            <div>
                <i class="fab fa-instagram mr-1"></i>
                <a href="https://www.instagram.com/@Model.Links.InstagramName" target="_blank">
                    @Model.Links.InstagramName
                </a>
            </div>
        </div>
    </div>
}