{
  "name": "odk.web.razor",
  "version": "1.0.0",
  "private": true,
  "description": "SCSS build pipeline for ODK.Web.Razor (Dart Sass).",
  "scripts": {
    "sass:css": "sass wwwroot/scss/main.scss:wwwroot/css/main.css wwwroot/scss/odk.scss:wwwroot/css/odk.css --style=expanded --no-source-map --quiet-deps --silence-deprecation=import,global-builtin,slash-div,color-functions",
    "sass:min": "sass wwwroot/scss/main.scss:wwwroot/css/main.min.css wwwroot/scss/odk.scss:wwwroot/css/odk.min.css --style=compressed --no-source-map --quiet-deps --silence-deprecation=import,global-builtin,slash-div,color-functions",
    "build:css": "npm run sass:css && npm run sass:min",
    "watch:css": "sass wwwroot/scss/main.scss:wwwroot/css/main.css wwwroot/scss/odk.scss:wwwroot/css/odk.css --style=expanded --no-source-map --quiet-deps --silence-deprecation=import,global-builtin,slash-div,color-functions --watch --update",
    "watch:min": "sass wwwroot/scss/main.scss:wwwroot/css/main.min.css wwwroot/scss/odk.scss:wwwroot/css/odk.min.css --style=compressed --no-source-map --quiet-deps --silence-deprecation=import,global-builtin,slash-div,color-functions --watch --update",
    "watch:sass": "concurrently -k -n css,min -c green,cyan \"npm:watch:css\" \"npm:watch:min\"",
    "dev:meetup": "concurrently -k -n dotnet,css,min -c blue,green,cyan \"dotnet watch run --urls=http://localhost:8123 --environment=Development\" \"npm:watch:css\" \"npm:watch:min\"",
    "dev:odk": "concurrently -k -n dotnet,css,min -c magenta,green,cyan \"dotnet watch --urls=http://localhost:8124\" \"npm:watch:css\" \"npm:watch:min\""
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "sass": "1.80.0"
  }
}
