@page "/my/groups/{chapterId:guid}/events"
@using ODK.Data.Core.Events
@using ODK.Services.Events
@using ODK.Web.Razor.Models.Admin
@using ODK.Web.Razor.Models.Components
@model ODK.Web.Razor.Pages.My.Groups.Events.IndexModel
@inject IEventAdminService EventAdminService
@{
    Layout = "_GroupAdminLayout";
    Model.Title = "Events";

    var request = Model.MemberChapterAdminServiceRequest;
    var filter = new EventAdminFilter
    {
        FromDate = Model.FromDate,
        ToDate = Model.ToDate,
        VenueId = Model.VenueId
    };
    var viewModel = await EventAdminService.GetEventsAdminPageViewModel(request, Model.Chapter, filter, Model.Page, Model.PageSize);
}

@await Html.PartialAsync("Components/_TwoColLeftMenu", new TwoColLeftMenuViewModel
{
    Title = "Events",
    BodyContentFunc = @<div>@await Html.PartialAsync("Admin/Events/_AdminEventsContent", viewModel)</div>,
    MenuContentFunc = _ => Html.PartialAsync("Admin/_AdminSideMenu")
})