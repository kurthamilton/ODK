@page "/privacy"
@using ODK.Core.Platforms
@using ODK.Services.Chapters
@using ODK.Web.Razor.Models.Components
@using ODK.Web.Razor.Models.Header
@model PrivacyModel
@inject IChapterService ChapterService
@{
    Layout = "_HomeLayout";
    Model.Title = "Privacy";
    Model.Description = "Privacy policy detailing how we handle data";
    Model.Path = "/privacy";
}

@if (Model.Platform == PlatformType.DrunkenKnitwits)
{
    var viewModel = await ChapterService.GetOdkHomeHeaderViewModel();
    @await Html.PartialAsync("Header/_OdkHomeHeader", viewModel)
}

@await Html.PartialAsync("Components/_Body", new BodyViewModel
{
    Content = await Html.PartialAsync("Privacy/_PrivacyBody", null),
    Title = "Privacy"
})