@page "/groups/{slug}/conversations/{id:guid}"
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@using ODK.Services.Chapters
@using ODK.Web.Common.Routes
@using ODK.Web.Razor.Models.Chapters
@using ODK.Web.Razor.Models.Components
@using ODK.Web.Razor.Models.Groups
@model ConversationModel
@inject IChapterViewModelService ChapterViewModelService
@inject IOdkRoutes OdkRoutes
@{
    Layout = "_HomeLayout";

    var viewModel = await ChapterViewModelService.GetGroupConversationPage(
        Model.MemberChapterServiceRequest, Model.ConversationId);

    Model.Title = $"{viewModel.Conversation.Subject} | My conversations | {viewModel.Chapter.GetDisplayName(Model.Platform)}";
}

@await Html.PartialAsync("Groups/_GroupBody", new GroupBodyViewModel
{
    Title = "",
    Content = await Html.PartialAsync("Conversations/_ConversationContent", new ChapterConversationViewModel
    {
        Breadcrumbs =
        [
            new MenuItem { Text = "My conversations", Link = OdkRoutes.Groups.Conversations(Model.Chapter) },
            new MenuItem { Text = viewModel.Conversation.Subject }
        ],
        Chapter = viewModel.Chapter,
        Conversation = viewModel.Conversation,
        ConversationUrlFunc = id => OdkRoutes.Groups.Conversation(chapter: Model.Chapter, id),
        CurrentMember = Model.CurrentMember,
        Messages = viewModel.Messages,
        OtherConversations = viewModel.OtherConversations
    }),
    Group = viewModel
})