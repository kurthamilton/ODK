@page "/{chapterName}/About"
@using ODK.Web.Razor.Models.Components
@using ODK.Web.Common.Components
@model ODK.Web.Razor.Pages.Chapters.AboutModel
@{
    Layout = "_ChapterLayout2";
    Model.Title = "About";

    var viewModel = Model.ViewModel;
}

@await Html.PartialAsync("Components/_Body", new BodyViewModel
{
    Title = "About",
    Breadcrumbs = new []
    {
        new MenuItem { Link = $"/{viewModel.Chapter.Name}", Text = viewModel.Chapter.Name },
        new MenuItem { Text = "About" }
    },
    Content = await Html.PartialAsync("About/_AboutContent", viewModel)
})