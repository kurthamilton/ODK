@page "/{chapterName}/Admin/Events"
@using ODK.Data.Core.Events
@using ODK.Services.Events
@using ODK.Web.Razor.Models.Admin
@model EventsModel
@inject IEventAdminService EventAdminService
@{
    Layout = "_OdkChapterAdminLayout";
    Model.Title = "Events | Admin";

    var request = Model.MemberChapterAdminServiceRequest;
    var viewModel = await EventAdminService.GetEventsAdminPageViewModel(
        request, Model.Chapter, Model.Filter, Model.PageFilter);
}

@await Html.PartialAsync("Admin/_AdminBody", new AdminBodyViewModel
{
    Title = "Events",
    ContentFunc = @<div>@await Html.PartialAsync("Admin/Events/_AdminEventsContent", viewModel)</div>
})