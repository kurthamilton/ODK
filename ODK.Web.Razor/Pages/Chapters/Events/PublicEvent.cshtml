@page "/{chapterName}/Events/Public/{id:guid}"
@using ODK.Web.Common.Components
@using ODK.Web.Razor.Models.Components
@model ODK.Web.Razor.Pages.Chapters.Events.PublicEventModel
@{
    Layout = "_ChapterLayout2";
    Model.Title = Model.ViewModel.Event.Name;

    var chapter = Model.ViewModel.Chapter;
}

@await Html.PartialAsync("Components/_BodyWithSidebar", new BodyWithSidebarViewModel
{
   Title = Model.ViewModel.Event.Name,
   Breadcrumbs = new []
   {
       new MenuItem { Link = $"/{chapter.Name}", Text = chapter.Name },
       new MenuItem { Link = $"/{chapter.Name}/Events", Text = "Events" },
       new MenuItem { Text = Model.ViewModel.Event.Name }
   },
   Content = await Html.PartialAsync("Events/_EventContent", Model),
   SidebarContent = await Html.PartialAsync("Events/_EventSidebar", Model)
})