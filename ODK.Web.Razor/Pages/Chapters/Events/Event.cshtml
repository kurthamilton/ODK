@page "/{chapterName}/Events/{id:guid}"
@attribute [Authorize]
@using ODK.Web.Razor.Models.Components
@using ODK.Web.Common.Components
@using ODK.Web.Razor.Models.Events
@using Microsoft.AspNetCore.Authorization
@model EventModel
@{
    Layout = "_ChapterLayout2";
    Model.Title = Model.ViewModel.Event.Name;

    var viewModel = Model.ViewModel;
    var chapter = viewModel.Chapter;
}

@await Html.PartialAsync("Components/_BodyWithSidebar", new BodyWithSidebarViewModel
{
    Title = viewModel.Event.Name,
    Breadcrumbs = new []
    {
        new MenuItem { Link = $"/{chapter.Name}", Text = chapter.Name },
        new MenuItem { Link = $"/{chapter.Name}/Events", Text = "Events" },
        new MenuItem { Text = viewModel.Event.Name }
    },
    Content = await Html.PartialAsync("Events/_EventContent", viewModel),
    SidebarContent = await Html.PartialAsync("Events/_EventSidebar", viewModel)
})